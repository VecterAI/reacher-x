# ============================================
# ReacherX Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ============================================
# Required: Core App Configuration
# ============================================

# Convex client URL for the Next.js app
NEXT_PUBLIC_CONVEX_URL=

# WorkOS application client ID
WORKOS_CLIENT_ID=

# Primary AI provider used by agents and most AI product flows
OPENROUTER_API_KEY=

# Public site URL used by the web app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Convex site URL used for webhook registration and callback construction
# Example: https://your-deployment.convex.site
CONVEX_SITE_URL=

# ============================================
# Required: X/Twitter
# ============================================

# X OAuth app
X_API_CLIENT_ID=
X_API_CLIENT_SECRET=
X_API_BEARER_TOKEN=

# OAuth 1.0 Consumer Secret (API Key Secret) — required for webhook CRC + POST signatures (not the OAuth 2 client secret above)
X_CONSUMER_SECRET=

# Secret used to encrypt stored X access/refresh tokens before persisting them
X_TOKEN_ENCRYPTION_KEY=

# ============================================
# Required: LinkedIn
# ============================================

# LinkedIn search and profile data
LINKDAPI_API_KEY=

# LinkedIn messaging and actions
UNIPILE_API_KEY=
UNIPILE_BASE_URL=
UNIPILE_WEBHOOK_SECRET=

# ============================================
# Required: External Services
# ============================================

# Twitter search, hydration, and monitoring
SOCIALAPI_API_KEY=

# Transactional email
RESEND_API_KEY=

# ============================================
# Required: Billing
# ============================================

POLAR_ORGANIZATION_TOKEN=
POLAR_PRODUCT_HOBBY_MONTHLY=
POLAR_PRODUCT_HOBBY_YEARLY=
POLAR_PRODUCT_BASE_MONTHLY=
POLAR_PRODUCT_BASE_YEARLY=
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_PRO_YEARLY=

# Optional. Defaults to sandbox if unset.
# POLAR_SERVER=sandbox

# ============================================
# Optional: AI Providers And Fallbacks
# ============================================

# Embeddings fallback if OpenRouter is unavailable
OPENAI_API_KEY=

# Optional xAI usage
XAI_API_KEY=
# XAI_BASE_URL=

# ============================================
# Optional: Product And Content Helpers
# ============================================

# URL content extraction
EXA_API_KEY=

# Keyword discovery
BISHOPI_API_KEY=

# GitHub API token for higher-rate metadata fetches
GITHUB_TOKEN=

# ============================================
# Optional: Analytics & Monitoring
# ============================================

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# Optional: Rate Limits And Runtime Tuning
# ============================================

# LINKDAPI_REQUESTS_PER_MINUTE=30
# LINKDAPI_TARGET_REQUESTS_PER_MINUTE=24
# PROSPECTING_AUTO_RESCHEDULE=1
# PROSPECTING_RESCHEDULE_INTERVAL_MINUTES=60

# ============================================
# Optional: Feature Flags
# ============================================

# Disable AI filtering (for testing)
# NEXT_PUBLIC_DISABLE_LLM_FILTER=

# Enable the fast partial setup preview path
# SETUP_PREVIEW_FAST_PATH=1
